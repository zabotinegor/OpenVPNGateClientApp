# Merged .gitignore
# This file was created by merging the project's .gitignore files.
# =============================================================
# Standard-Android/Gradle-Ignores (from src/.gitignore)
*.iml
.gradle
local.properties
.DS_Store
.externalNativeBuild
.cxx
keystore.properties
servers.local.json

# IDE-files-and-directories
# Ignoring the entire .idea directory is a common and safe practice.
.idea/
.vscode/

# Build-output-from-all-modules
# ==================================
/build/
/src/build/
/src/core/build/
/src/mobile/build/
/src/tv/build/

# Build type outputs
/src/mobile/release/
/src/tv/release/
/src/core/release/

# Captures-directory
/captures/

# Other-Ignores
# =================
# APK-files
*.apk
*.signed.apk

# Keystore
/keystore/

# Kotlin caches and error logs
**/.kotlin/
src/.kotlin/
src/.kotlin/errors/*.log

# Local overlay files — machine-specific paths and context, never committed
AGENTS.local.md
README.local.md

